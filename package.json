{
    "name": "zotero-latex-cite",
    "displayName": "Zotero LaTeX Citation Picker",
    "description": "Zotero Better Bibtex citation picker for VS Code with LaTeX support",
    "version": "0.1.0",
    "publisher": "mark9804",
    "author": {
        "name": "mark9804",
        "email": "mark.zhaolu.chen@rikkyo.ac.jp",
        "url": "https://mark9804.github.io"
    },
    "contributors": [
        {
            "name": "Matti Vuorre",
            "email": "mjvuorre@uvt.nl",
            "url": "https://vuorre.com"
        },
        {
            "name": "Matthew Blode",
            "email": "m@blode.co",
            "url": "https://matthewblode.com"
        }
    ],
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "package": "npx -y @vscode/vsce package"
    },
    "homepage": "https://github.com/mvuorre/vscode-zotero",
    "bugs": {
        "url": "https://github.com/mvuorre/vscode-zotero/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/mvuorre/vscode-zotero.git"
    },
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.84.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "markdown",
        "zotero",
        "betterbibtex",
        "better bibtex",
        "citations"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.zoteroCitationPicker",
                "title": "Zotero Citation Picker"
            }
        ],
        "keybindings": [
            {
                "command": "extension.zoteroCitationPicker",
                "key": "alt+shift+z"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Zotero Citation Picker",
            "properties": {
                "zotero-citation-picker.port": {
                    "type": "string",
                    "default": "http://127.0.0.1:23119/better-bibtex/cayw?format=pandoc",
                    "description": "Customise what port/URL will be used for the picker."
                },
                "zotero-citation-picker.citeMethod": {
                    "type": "string",
                    "enum": ["zotero", "vscode"],
                    "enumDescriptions": ["Use the Zotero Cite as you Write popup", "Use a picker within VS Code"],
                    "default": "vscode",
                    "markdownDescription": "Controls how Zotero citations are chosen"
                }
            }
        }
    },
    "devDependencies": {
        "@types/mocha": "^10.0.3",
        "@types/node": "18.x",
        "@types/request-promise": "^4.1.50",
        "@types/vscode": "^1.84.0",
        "@typescript-eslint/eslint-plugin": "^6.9.0",
        "@typescript-eslint/parser": "^6.9.0",
        "@vscode/test-electron": "^2.3.6",
        "eslint": "^8.52.0",
        "glob": "^10.3.10",
        "mocha": "^10.2.0",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "request": "^2.88.0",
        "request-promise": "^4.2.5"
    }
}
